# Copy to deploy/env/staging.app.env on the remote QEMU host.
# Staging must use sandbox providers or masked/read-only provider data unless a
# write path has explicit non-production approval.
ENVIRONMENT_ROLE=staging
ENVIRONMENT_DATA_MODE=masked-read-only
ENVIRONMENT_DATA_SOURCE=masked-production-derived
APP_ENV=staging
APP_PORT=8080
DATABASE_URL=postgres://provisioner_staging:replace-with-generated-staging-db-password@postgres-staging:5432/provisioner_staging?sslmode=disable
SESSION_SECRET=replace-with-generated-staging-session-secret
ENCRYPTION_KEY=k1:replace-with-generated-staging-encryption-key
GOOGLE_REDIRECT_URL=https://wizard-staging.example.org/auth/callback
GOOGLE_ALLOWED_GROUPS_CONFIG={}
USE_MOCK_ZOOM=true
USE_MOCK_GOOGLE=true
USE_MOCK_AERIES=false
USE_MOCK_SFTP=true
AERIES_READ_ONLY=true
AERIES_DATABASE_YEAR_MODE=previous_school_year
AERIES_MASKED_PREVIOUS_YEAR_ONLY=true
AERIES_BASE_URL=https://replace-with-masked-readonly-aeries-host/api
AERIES_CERT_FILE=/run/secrets/aeries-staging-client-cert.pem
ZOOM_SLG_MAX_MEMBERS=10
