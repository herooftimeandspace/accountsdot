# Copy to deploy/env/dev.app.env on the remote QEMU host.
# Dev is mock-backed by default and uses the long-lived postgres-dev volume.
ENVIRONMENT_ROLE=dev
ENVIRONMENT_DATA_MODE=mock
APP_ENV=development
APP_PORT=8080
DATABASE_URL=postgres://provisioner_dev:replace-with-generated-dev-db-password@postgres-dev:5432/provisioner_dev?sslmode=disable
SESSION_SECRET=replace-with-generated-dev-session-secret
ENCRYPTION_KEY=k1:replace-with-generated-dev-encryption-key
GOOGLE_REDIRECT_URL=https://wizard-dev.example.org/auth/callback
GOOGLE_ALLOWED_GROUPS_CONFIG={}
USE_MOCK_ZOOM=true
USE_MOCK_GOOGLE=true
USE_MOCK_AERIES=true
USE_MOCK_SFTP=true
ZOOM_SLG_MAX_MEMBERS=10
