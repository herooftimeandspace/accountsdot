# Copy to deploy/env/main.app.env on the remote QEMU host.
# Main must use production credentials and the main database only. Do not reuse
# dev or staging secrets.
ENVIRONMENT_ROLE=main
ENVIRONMENT_DATA_MODE=production
APP_ENV=production
APP_PORT=8080
DATABASE_URL=postgres://provisioner_main:replace-with-generated-main-db-password@postgres-main:5432/provisioner_main?sslmode=disable
SESSION_SECRET=replace-with-generated-main-session-secret
ENCRYPTION_KEY=k1:replace-with-generated-main-encryption-key
GOOGLE_REDIRECT_URL=https://wizard.example.org/auth/callback
GOOGLE_ALLOWED_GROUPS_CONFIG={}
USE_MOCK_ZOOM=false
USE_MOCK_GOOGLE=false
USE_MOCK_AERIES=false
USE_MOCK_SFTP=false
ZOOM_SLG_MAX_MEMBERS=10
