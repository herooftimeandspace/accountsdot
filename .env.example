APP_ENV=development
APP_PORT=8080

# Copy this file to .env and fill local-only secrets there. Do not commit .env.
POSTGRES_PASSWORD=
DATABASE_URL=
SESSION_SECRET=
ENCRYPTION_KEY=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8080/auth/callback
GOOGLE_ALLOWED_GROUPS_CONFIG={}
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=

# Production Google SAML and authorization contract. Keep secrets and tenant
# metadata out of git; point these values at environment-managed URLs or files.
AUTH_ALLOWED_EMAIL_DOMAINS=wusd.org,it.wusd.org,staff.wusd.org
AUTH_DENIED_EMAIL_DOMAINS=stu.wusd.org
GOOGLE_SAML_ENTITY_ID=
GOOGLE_SAML_ACS_URL=
GOOGLE_SAML_IDP_METADATA_URL=
GOOGLE_SAML_IDP_SSO_URL=
GOOGLE_SAML_IDP_CERT_FILE=
GOOGLE_AUTH_GROUP_ROLE_MAPPINGS_JSON=[]
GOOGLE_AUTH_ATTRIBUTE_ROLE_MAPPINGS_JSON=[]
GOOGLE_AUTH_SITE_SCOPE_MAPPINGS_JSON=[]

ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_BASE_URL=https://api.zoom.us/v2
ZOOM_OAUTH_URL=https://zoom.us
ZOOM_SLG_MAX_MEMBERS=10

AERIES_BASE_URL=
AERIES_CLIENT_ID=
AERIES_CLIENT_SECRET=

SFTP_HOST=
SFTP_PORT=22
SFTP_USERNAME=
SFTP_PRIVATE_KEY=
SFTP_REMOTE_PATH=

USE_MOCK_ZOOM=true
USE_MOCK_GOOGLE=true
USE_MOCK_AERIES=true
USE_MOCK_SFTP=true
