{
  "name": "accountsdot",
  "private": true,
  "description": "Mock and documentation tooling for Go Employee Provisioner",
  "scripts": {
    "dev:api": "go run ./cmd/provisioner",
    "dev:web": "vite --config frontend/vite.config.mjs",
    "dev:persona": "node scripts/dev_persona_switch.mjs",
    "build:web": "vite build --config frontend/vite.config.mjs",
    "a11y:check": "node scripts/check_frontend_accessibility.mjs",
    "long-pages:self-test": "node scripts/dev_long_page_harness.mjs --self-test",
    "ci:local": "python3 scripts/run_local_ci.py",
    "docs:comments:check": "node scripts/check_doc_comment_quality.mjs",
    "docs:comments:test": "node scripts/check_doc_comment_quality.mjs --self-test",
    "route-api-inventory:check": "node scripts/check_route_api_authorization_inventory.mjs",
    "write-inventory:check": "node scripts/check_external_write_inventory.mjs",
    "write-inventory:test": "node scripts/check_external_write_inventory.mjs --self-test",
    "perf:routes:plan": "node scripts/dev_route_performance_matrix.mjs",
    "perf:routes:batch-plan": "node scripts/dev_route_performance_matrix.mjs batch-plan",
    "perf:routes:merge": "node scripts/dev_route_performance_matrix.mjs merge",
    "perf:routes:merge:strict": "node scripts/dev_route_performance_matrix.mjs merge --strict",
    "pen:sync": "node scripts/sync_implemented_pages.mjs",
    "pen:check": "node scripts/sync_implemented_pages.mjs --check",
    "pen:lint": "node scripts/lint_implemented_pages.mjs",
    "pen:lint:test": "node scripts/lint_implemented_pages.mjs --self-test",
    "pen:export": "node docs/mocks/export_pen_assets.mjs",
    "vendor:lucide": "node docs/mocks/vendor_lucide.mjs",
    "render:wireframes": "node docs/mocks/render_wireframes.mjs",
    "export:wireframes": "node docs/mocks/export_wireframes_with_pencil.mjs"
  },
  "dependencies": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "lucide-static": "0.542.0",
    "vite": "^8.0.10"
  }
}
